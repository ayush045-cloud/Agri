# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL — use the Neon POOLER endpoint at runtime.
# For Neon DB this is the "-pooler" hostname (no pgbouncer=true needed with Prisma 5+).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct (non-pooled) URL — used by Prisma for migrations only.
# OPTIONAL on Railway: startup.sh auto-derives this from DATABASE_URL
# by removing "-pooler" from the hostname when this variable is not set.
# Set it explicitly if your Neon project uses a custom hostname.
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Allowed CORS origin(s) — set to your Vercel frontend URL in production:
CORS_ORIGIN=https://your-vercel-app.vercel.app

# ── AI / LLM ──────────────────────────────────────────────
# Provide ONE of the two keys; Gemini is preferred.
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"   # fallback

# ── Python AI Microservice ────────────────────────────────
# Railway internal hostname — always include the http:// protocol prefix.
# Format for Railway service-to-service: http://<service-name>.railway.internal
AI_SERVICE_URL="http://agri.railway.internal"

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
