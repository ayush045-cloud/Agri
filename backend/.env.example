# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL (pooler URL used at runtime, e.g. Neon DB)
# For Neon DB add pgbouncer=true to the pooler URL:
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection URL — used by Prisma for migrations only.
# For Neon DB this is the non-pooler endpoint (omit the "-pooler" part):
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Allowed CORS origin(s) — set to your frontend URL in production
CORS_ORIGIN=*

# ── AI / LLM ──────────────────────────────────────────────
# Provide ONE of the two keys; Gemini is preferred.
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"   # fallback

# ── Python AI Microservice ────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
