# ── Database ──────────────────────────────────────────────
# PostgreSQL connection URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/agro_mind"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AI / LLM ──────────────────────────────────────────────
# Provide ONE of the two keys; Gemini is preferred.
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"   # fallback

# ── Python AI Microservice ────────────────────────────────
AI_SERVICE_URL="http://localhost:8000"

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
