<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.AgroMind" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_600</item>
        <item name="colorPrimaryVariant">@color/green_800</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorSecondary">@color/amber_500</item>
        <item name="colorOnSecondary">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_900</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorError">@color/red_600</item>
        <item name="android:statusBarColor">@color/green_800</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
    </style>

    <style name="ShapeSmall" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeMedium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Card style -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Primary button -->
    <style name="BtnPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_600</item>
        <item name="android:textColor">@color/surface</item>
        <item name="android:textSize">13.5sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">9dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Secondary button -->
    <style name="BtnSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_700</item>
        <item name="android:textSize">13.5sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">9dp</item>
        <item name="android:paddingBottom">9dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Form input -->
    <style name="FormInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/text_300</item>
        <item name="android:textColorHint">@color/text_300</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Switch style -->
    <style name="GreenSwitch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="colorControlActivated">@color/green_500</item>
    </style>

    <!-- Section card title text -->
    <style name="CardTitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_700</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Stat value -->
    <style name="StatValue">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <!-- Stat label -->
    <style name="StatLabel">
        <item name="android:textSize">10.5sp</item>
        <item name="android:textColor">@color/text_300</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Badge (chip-like status indicator) -->
    <style name="Badge">
        <item name="android:textSize">10.5sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <!-- Page header title -->
    <style name="PageTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_900</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Page header subtitle -->
    <style name="PageSubtitle">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_300</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Quick chat chip -->
    <style name="QuickChip" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_700</item>
        <item name="android:textSize">12.5sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">7dp</item>
        <item name="android:paddingBottom">7dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="elevation">0dp</item>
    </style>
</resources>
