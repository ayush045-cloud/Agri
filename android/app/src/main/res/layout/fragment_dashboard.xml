<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="32dp">

        <!-- ── PAGE HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_dashboard"
                    style="@style/PageTitle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle_dashboard"
                    style="@style/PageSubtitle"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_add_field"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_field"
                style="@style/BtnPrimary" />
        </LinearLayout>

        <!-- ── STAT CARDS — row 1 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Water Saved -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:elevation="0dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_stat_green" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💧" android:textSize="24sp" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_water_saved" style="@style/StatLabel" />

                    <TextView
                        android:id="@+id/tv_stat_water"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1,840 L" style="@style/StatValue"
                        android:layout_marginTop="4dp" android:layout_marginBottom="3dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↑ 12% vs yesterday" android:textSize="11.5sp"
                        android:textColor="@color/green_500" />
                </LinearLayout>
            </LinearLayout>

            <!-- Avg Soil Moisture -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_stat_amber" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌱" android:textSize="24sp" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_soil_moisture" style="@style/StatLabel" />

                    <TextView
                        android:id="@+id/tv_stat_moisture"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="68%" style="@style/StatValue"
                        android:layout_marginTop="4dp" android:layout_marginBottom="3dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↑ Optimal range" android:textSize="11.5sp"
                        android:textColor="@color/green_500" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── STAT CARDS — row 2 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Active Fields -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_stat_blue" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌾" android:textSize="24sp" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_active_fields" style="@style/StatLabel" />

                    <TextView
                        android:id="@+id/tv_stat_fields"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="6" style="@style/StatValue"
                        android:layout_marginTop="4dp" android:layout_marginBottom="3dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="4 irrigated today" android:textSize="11.5sp"
                        android:textColor="@color/text_300" />
                </LinearLayout>
            </LinearLayout>

            <!-- Disease Alerts -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/gradient_stat_red" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚠️" android:textSize="24sp" android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_disease_alerts" style="@style/StatLabel" />

                    <TextView
                        android:id="@+id/tv_stat_disease"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2" style="@style/StatValue"
                        android:layout_marginTop="4dp" android:layout_marginBottom="3dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Wheat blight risk" android:textSize="11.5sp"
                        android:textColor="@color/red_600" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SOIL MOISTURE CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌱 " android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/soil_moisture_by_field" style="@style/CardTitle" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_soil_moisture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- ── RECENT ALERTS CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔔 " android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/recent_alerts" style="@style/CardTitle" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_alerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- ── WEEKLY WATER USAGE CHART CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📈 " android:textSize="16sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/weekly_water_usage" style="@style/CardTitle" />
            </LinearLayout>

            <!-- Bar Chart Container -->
            <LinearLayout
                android:id="@+id/ll_bar_chart"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:paddingBottom="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
