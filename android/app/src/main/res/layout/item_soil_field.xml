<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="10dp"
    android:paddingTop="2dp">

    <!-- Field name -->
    <TextView
        android:id="@+id/tv_field_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_700"
        android:textStyle="bold"
        android:layout_marginBottom="5dp" />

    <!-- Progress row: track + percentage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="8dp"
            android:background="@drawable/bg_progress_track"
            android:layout_marginEnd="10dp">

            <View
                android:id="@+id/view_moisture_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill_green" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_moisture_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_700"
            android:textStyle="bold"
            android:minWidth="36dp"
            android:gravity="end" />
    </LinearLayout>
</LinearLayout>
