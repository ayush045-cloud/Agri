<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <!-- ══════════ MAIN CONTENT ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg">

        <!-- ── TOP BAR ── -->
        <LinearLayout
            android:id="@+id/topbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:background="@color/surface"
            android:elevation="2dp">

            <!-- Hamburger / nav icon -->
            <ImageButton
                android:id="@+id/btn_hamburger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/navigation_drawer_open"
                android:tint="@color/text_700" />

            <!-- Brand icon -->
            <TextView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:text="🌿"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_green"
                android:padding="4dp" />

            <!-- Title + subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_topbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_dashboard"
                    android:textSize="15sp"
                    android:textColor="@color/text_900"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tv_last_updated"
                    android:text="@string/last_updated"
                    android:textSize="11sp"
                    android:textColor="@color/text_300"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Weather chip -->
            <TextView
                android:id="@+id/chip_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weather_chip"
                android:textSize="11.5sp"
                android:textColor="@color/blue_600"
                android:background="@drawable/bg_badge_blue"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="6dp" />

            <!-- Alert chip -->
            <TextView
                android:id="@+id/chip_alert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alert_chip"
                android:textSize="11.5sp"
                android:textColor="#c45400"
                android:background="@drawable/bg_badge_amber"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Divider below topbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border" />

        <!-- ── FRAGMENT CONTAINER ── -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph" />

        <!-- ── BOTTOM NAVIGATION (phones) ── -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:menu="@menu/bottom_nav_menu"
            app:itemIconTint="@color/text_300"
            app:itemTextColor="@color/text_300"
            app:itemActiveIndicatorColor="@color/green_100"
            app:labelVisibilityMode="labeled"
            android:elevation="8dp" />

    </LinearLayout>

    <!-- ══════════ NAVIGATION DRAWER ══════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/green_800"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/nav_drawer_menu"
        app:itemTextColor="@color/green_200"
        app:itemIconTint="@color/green_200"
        app:itemBackground="@android:color/transparent" />

</androidx.drawerlayout.widget.DrawerLayout>
